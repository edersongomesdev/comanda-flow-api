PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:4173
# Optional: comma-separated extra frontend origins allowed by CORS.
FRONTEND_URLS=
# Optional: comma-separated Vercel project names allowed for preview/prod origins,
# e.g. comanda-flow-studio -> https://comanda-flow-studio.vercel.app and preview URLs.
FRONTEND_VERCEL_PROJECTS=

DATABASE_URL=postgresql://postgres:postgres@db.example.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:postgres@db.example.supabase.co:5432/postgres

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# START -> STRIPE_PRICE_START
STRIPE_PRICE_START=
# ESSENCIAL -> STRIPE_PRICE_ESSENCIAL
STRIPE_PRICE_ESSENCIAL=
# MESA -> STRIPE_PRICE_MESA
STRIPE_PRICE_MESA=
# PREMIUM -> STRIPE_PRICE_PREMIUM
STRIPE_PRICE_PREMIUM=

# Supabase Storage
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=menu-assets
